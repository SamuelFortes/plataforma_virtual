# =============================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha
# =============================================================

# --- Banco de dados (PostgreSQL) ---
# Deixe em branco para usar SQLite local automaticamente
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=

# --- JWT ---
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# --- Recuperação de senha (link "Esqueci minha senha") ---
# Validade do link enviado por e-mail, em minutos
PASSWORD_RESET_EXPIRE_MINUTES=30

# --- Envio de e-mail ---
# Escolha UM transporte. Prioridade: Brevo (BREVO_API_KEY) > SMTP
# (SMTP_HOST/USER/PASSWORD) > Resend (EMAIL_API_KEY). Se nenhum, só loga.
#
# Opção A) Brevo (API HTTP) — RECOMENDADO no Render free (usa porta 443; as portas
# de SMTP são bloqueadas no plano gratuito). Não exige domínio: basta verificar
# o e-mail remetente no painel do Brevo.
BREVO_API_KEY=
#
# Opção B) SMTP (ex.: Gmail com senha de app — exige 2FA na conta).
# ATENÇÃO: não funciona no plano free do Render (portas SMTP bloqueadas).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
#
# Opção C) Resend (API HTTP) — exige domínio verificado para enviar a terceiros:
EMAIL_API_KEY=
#
# Remetente exibido (aceita "Nome <email>" ou só "email"; se vazio, usa SMTP_USER).
# No Brevo, o e-mail aqui precisa estar verificado como remetente:
EMAIL_FROM=MeuTerritório <meuterritorio.envios@gmail.com>

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Render (produção) ---
# Deixe em branco no desenvolvimento local
RENDER_EXTERNAL_URL=
