# =============================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha
# =============================================================

# --- Banco de dados (PostgreSQL) ---
# Deixe em branco para usar SQLite local automaticamente
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=

# --- JWT ---
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Render (produção) ---
# Deixe em branco no desenvolvimento local
RENDER_EXTERNAL_URL=
