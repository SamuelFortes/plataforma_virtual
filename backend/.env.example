# =============================================================
# Variáveis de ambiente — copie este arquivo para .env e preencha
# =============================================================

# --- Banco de dados (PostgreSQL) ---
# Deixe em branco para usar SQLite local automaticamente
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DB_NAME=

# --- JWT ---
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=60

# --- Recuperação de senha (link "Esqueci minha senha") ---
# Validade do link enviado por e-mail, em minutos
PASSWORD_RESET_EXPIRE_MINUTES=30

# --- Envio de e-mail ---
# Escolha UM transporte. O código usa SMTP se SMTP_HOST/USER/PASSWORD estiverem
# preenchidos; senão usa Resend (EMAIL_API_KEY); senão só loga o conteúdo.
#
# Opção A) SMTP (ex.: Gmail com senha de app — exige 2FA na conta):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Remetente exibido (se vazio, usa SMTP_USER):
EMAIL_FROM=MeuTerritório <meuterritorio.envios@gmail.com>
#
# Opção B) Resend (API HTTP) — alternativa ao SMTP:
EMAIL_API_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Render (produção) ---
# Deixe em branco no desenvolvimento local
RENDER_EXTERNAL_URL=
